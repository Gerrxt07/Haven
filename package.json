{
	"name": "haven",
	"version": "2026.4.4",
	"description": "Your new Voice, Video and Chat application to connect with your friends!",
	"author": "Cloudly <haven@becloudly.eu>",
	"license": "LicenseRef-Haven-SAL-1.0",
	"main": "dist-electron/main.js",
	"private": true,
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-conventional": "20.5.0",
		"@electron/fuses": "2.1.1",
		"@eslint/js": "10.0.1",
		"@tailwindcss/postcss": "4.2.2",
		"@types/bun": "latest",
		"@types/node": "25.5.2",
		"autoprefixer": "10.4.27",
		"electron": "42.0.0-alpha.6",
		"electron-builder": "26.8.1",
		"esbuild": "0.28.0",
		"eslint": "10.2.0",
		"husky": "9.1.7",
		"knip": "6.3.0",
		"lint-staged": "16.4.0",
		"postcss": "8.5.8",
		"shadcn-solid": "0.7.7",
		"tailwindcss": "4.2.2",
		"typescript": "6.0.2",
		"typescript-eslint": "8.58.0",
		"vite": "8.0.3",
		"vite-plugin-electron": "0.29.1",
		"vite-plugin-electron-renderer": "0.14.6",
		"vite-plugin-solid": "2.11.11"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"format": "biome check --write --unsafe .",
		"lint": "biome check .",
		"lint-staged": "lint-staged",
		"knip": "knip",
		"prepare": "husky",
		"check": "bun run format && bun run typecheck",
		"dev": "bun run check && vite",
		"dev:updater-ui": "bun ./scripts/dev-updater-ui.cjs",
		"build": "bun run check && vite build",
		"package:win": "bun run build && bun run protect && electron-builder --win --publish never",
		"package:mac": "bun run build && bun run protect && electron-builder --mac --publish never",
		"package:linux": "bun run build && bun run protect && electron-builder --linux --publish never",
		"build:bytecode": "node ./scripts/build-bytecode.cjs",
		"build:integrity": "bun ./scripts/build-integrity-manifest.mjs",
		"protect": "bun run build:bytecode && bun run build:integrity"
	},
	"build": {
		"appId": "com.haven.app",
		"productName": "Haven",
		"generateUpdatesFilesForAllChannels": true,
		"publish": [
			{
				"provider": "github",
				"owner": "gerrxt07",
				"repo": "haven"
			}
		],
		"icon": "public/logo.png",
		"directories": {
			"output": "release",
			"buildResources": "build"
		},
		"files": [
			"dist/**",
			"dist-electron/**",
			"package.json"
		],
		"mac": {
			"target": [
				"dmg",
				"zip"
			]
		},
		"win": {
			"target": [
				"nsis",
				"zip"
			],
			"publish": [
				{
					"provider": "github",
					"owner": "gerrxt07",
					"repo": "haven"
				}
			]
		},
		"nsis": {
			"artifactName": "Haven-Setup-${version}.${ext}",
			"differentialPackage": true
		},
		"linux": {
			"target": [
				"AppImage",
				"deb"
			]
		},
		"afterPack": "./scripts/apply-electron-fuses.cjs",
		"asar": true
	},
	"dependencies": {
		"@chenglou/pretext": "0.0.4",
		"@kobalte/core": "0.13.11",
		"@tanstack/solid-query": "5.96.1",
		"@tanstack/solid-virtual": "3.13.23",
		"bytenode": "1.5.7",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"electron-log": "5.4.3",
		"electron-updater": "6.8.3",
		"email-validator": "2.0.4",
		"libsodium-wrappers-sumo": "0.8.2",
		"lucide-solid": "1.7.0",
		"solid-js": "1.9.12",
		"solid-motionone": "1.0.4",
		"tailwind-merge": "3.5.0",
		"tailwindcss-animate": "1.0.7"
	},
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}
