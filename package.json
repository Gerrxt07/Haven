{
  "name": "haven",
  "version": "2026.03.30",
  "description": "Your new Voice, Video and Chat application to connect with your friends!",
  "author": "Cloudly <haven@becloudly.eu>",
  "license": "AGPL-3.0-only",
  "main": "dist-electron/main.js",
  "private": true,
  "devDependencies": {
    "@electron/fuses": "2.1.1",
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "electron": "42.0.0-alpha.6",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check": "bun run typecheck && bun run lint",
    "dev": "bun run check && vite",
    "build": "bun run check && vite build",
    "package": "bun run build && bun run protect && electron-builder",
    "package:win": "bun run build && bun run protect && electron-builder --win",
    "package:mac": "bun run build && bun run protect && electron-builder --mac",
    "package:linux": "bun run build && bun run protect && electron-builder --linux",
    "build:bytecode": "node ./scripts/build-bytecode.cjs",
    "build:integrity": "node ./scripts/build-integrity-manifest.mjs",
    "protect": "bun run build:bytecode && bun run build:integrity"
  },
  "build": {
    "appId": "com.haven.app",
    "productName": "Haven",
    "icon": "public/logo.png",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "afterSign": "./scripts/apply-electron-fuses.cjs",
    "asar": true
  },
  "dependencies": {
    "bytenode": "1.5.7"
  }
}