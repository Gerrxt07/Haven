{
	"name": "haven",
	"version": "2026.4.1",
	"description": "Your new Voice, Video and Chat application to connect with your friends!",
	"author": "Cloudly <haven@becloudly.eu>",
	"license": "LicenseRef-Haven-SAL-1.0",
	"main": "dist-electron/main.js",
	"private": true,
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-conventional": "20.5.0",
		"@electron/fuses": "2.1.1",
		"@eslint/js": "10.0.1",
		"@tailwindcss/postcss": "4.2.2",
		"@testing-library/jest-dom": "6.9.1",
		"@types/bun": "latest",
		"@types/node": "25.5.0",
		"autoprefixer": "10.4.27",
		"cspell": "9.7.0",
		"electron": "42.0.0-alpha.6",
		"electron-builder": "26.8.1",
		"esbuild": "0.27.4",
		"eslint": "10.1.0",
		"husky": "9.1.7",
		"jsdom": "29.0.1",
		"knip": "6.2.0",
		"lint-staged": "16.4.0",
		"postcss": "8.5.8",
		"typescript": "6.0.2",
		"typescript-eslint": "8.58.0",
		"vite": "8.0.3",
		"vite-plugin-electron": "0.29.1",
		"vite-plugin-electron-renderer": "0.14.6",
		"vite-plugin-solid": "2.11.11",
		"vitest": "4.1.2"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"format": "biome check --write --unsafe .",
		"lint": "biome check .",
		"knip": "knip",
		"spellcheck": "cspell \"**/*.{ts,tsx,js,jsx,md,json}\"",
		"test": "vitest run --passWithNoTests",
		"check": "bun run format && bun run typecheck && bun run knip && bun run spellcheck && bun run test",
		"dev": "bun run check && vite",
		"dev:strict": "bun run check && vite",
		"build": "bun run check && vite build",
		"package": "bun run build && bun run protect && electron-builder --publish never",
		"package:win": "bun run build && bun run protect && electron-builder --win --publish never",
		"package:mac": "bun run build && bun run protect && electron-builder --mac --publish never",
		"package:linux": "bun run build && bun run protect && electron-builder --linux --publish never",
		"build:bytecode": "node ./scripts/build-bytecode.cjs",
		"build:integrity": "bun ./scripts/build-integrity-manifest.mjs",
		"protect": "bun run build:bytecode && bun run build:integrity",
		"prepare": "husky"
	},
	"build": {
		"appId": "com.haven.app",
		"productName": "Haven",
		"icon": "public/logo.png",
		"directories": {
			"output": "release",
			"buildResources": "build"
		},
		"files": [
			"dist/**",
			"dist-electron/**",
			"package.json"
		],
		"mac": {
			"target": [
				"dmg",
				"zip"
			]
		},
		"win": {
			"target": [
				"nsis",
				"zip"
			]
		},
		"linux": {
			"target": [
				"AppImage",
				"deb"
			]
		},
		"afterPack": "./scripts/apply-electron-fuses.cjs",
		"asar": true
	},
	"dependencies": {
		"bytenode": "1.5.7",
		"lucide-solid": "1.7.0",
		"solid-js": "1.9.12"
	},
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}
