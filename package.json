{
	"name": "haven",
	"version": "2026.4.15",
	"description": "Your new Voice, Video and Chat application to connect with your friends!",
	"author": "Cloudly <haven@becloudly.eu>",
	"license": "LicenseRef-Haven-SAL-1.0",
	"private": true,
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-conventional": "20.5.0",
		"@eslint/js": "10.0.1",
		"@tailwindcss/postcss": "4.2.2",
		"@tauri-apps/cli": "^2.9.2",
		"@types/bun": "latest",
		"@types/node": "25.5.2",
		"autoprefixer": "10.4.27",
		"eslint": "10.2.0",
		"husky": "9.1.7",
		"knip": "6.3.1",
		"lint-staged": "16.4.0",
		"postcss": "8.5.9",
		"shadcn-solid": "0.7.7",
		"tailwindcss": "4.2.2",
		"typescript": "6.0.2",
		"typescript-eslint": "8.58.1",
		"vite": "8.0.8",
		"vite-plugin-electron": "0.29.1",
		"vite-plugin-electron-renderer": "0.14.6",
		"vite-plugin-solid": "2.11.12"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"format": "biome check --write --unsafe .",
		"lint": "biome check .",
		"lint-staged": "lint-staged",
		"knip": "knip",
		"prepare": "husky",
		"check": "bun run format && bun run typecheck",
		"dev": "bun run check && tauri dev",
		"build:web": "bun run check && vite build",
		"build": "bun run build:web && tauri build",
		"tauri": "tauri",
		"package:win": "bun run build -- --bundles nsis",
		"package:mac": "bun run build -- --bundles dmg,app",
		"package:linux": "bun run build -- --bundles appimage,deb"
	},
	"dependencies": {
		"@chenglou/pretext": "0.0.5",
		"@kobalte/core": "0.13.11",
		"@tauri-apps/api": "^2.8.0",
		"@tanstack/solid-query": "5.99.0",
		"@tanstack/solid-virtual": "3.13.23",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"email-validator": "2.0.4",
		"libsodium-wrappers-sumo": "0.8.3",
		"lucide-solid": "1.8.0",
		"solid-js": "1.9.12",
		"solid-motionone": "1.0.4",
		"tailwind-merge": "3.5.0",
		"tailwindcss-animate": "1.0.7"
	},
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}
